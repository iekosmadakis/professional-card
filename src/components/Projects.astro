---
const { projects, currentPage, totalPages } = Astro.props;

import '../styles/projects.css';
---

<div class="container">
    <div class="projects-container">
        <div class="projects-header">
            <h1>My Projects</h1>
            <p>Here are some of the projects I have worked on. Feedback and suggestions are always welcome!</p>
        </div>

        <div class="projects-grid">
            {projects.map(project => (
                <div class="project-card">
                    <h3>{project.title}</h3>
                    <p>{project.description}</p>
                    <div class="project-links">
                        <a href={project.url} class="project-link" target="_blank" rel="noopener noreferrer" aria-label={`View ${project.title} live demo`}>
                            <i class="bi bi-globe"></i>
                            View Project
                        </a>
                        {project.github ? (
                            <a href={project.github} class="project-link" target="_blank" rel="noopener noreferrer" aria-label={`View ${project.title} source code on GitHub`}>
                                <i class="bi bi-github"></i>
                                GitHub
                            </a>
                        ) : (
                            <span class="project-link disabled" aria-label="Private repository">
                                <i class="bi bi-github"></i>
                                Private
                            </span>
                        )}
                    </div>
                </div>
            ))}
        </div>

        {totalPages > 1 && (
            <div class="pagination">
                {Array.from({ length: totalPages }, (_, i) => i + 1).map(page => (
                    <a
                        href={page === 1 ? '/projects' : `/projects/${page}`}
                        class:list={['pagination-link', { active: page === currentPage }]}
                        aria-label={`Go to page ${page}`}
                    >
                        {page}
                    </a>
                ))}
            </div>
        )}

        <div class="back-home">
            <a href="/self-hosted" class="back-link">
                <i class="bi bi-server"></i>
                Self-Hosted Projects
            </a>
            <a href="/" class="back-link">
                <i class="bi bi-arrow-left"></i>
                Back to Home
            </a>
        </div>
    </div>
</div>
