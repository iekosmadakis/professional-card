---
import Icon from './Icon.astro';

const { name, position, aboutMe, linkedin, github, profileImage } = Astro.props;

import '../styles/card.css';
---

<div class="container">
    <div class="card-container">
        <div class="description">
            <h1>{name}</h1>
            <h2>{position}</h2>
            <div class="about-me-content">
                <div class="section">
                    <p>{aboutMe.content}</p>
                    {aboutMe.closingNote && (
                        <p class="closing-note"><em>{aboutMe.closingNote}</em></p>
                    )}
                </div>
                <div class="section">
                    <h3>{aboutMe.highlights.title}</h3>
                    <ul>
                        {aboutMe.highlights.items.map(item => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </div>
            </div>
            <div class="icons">
                <a href="/projects" class="hover-text" aria-label="View Projects">
                    <span class="tooltip-text">Projects</span>
                    <Icon name="folder" />
                </a>
                <a href={linkedin} class="hover-text" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn Profile">
                    <span class="tooltip-text">LinkedIn</span>
                    <Icon name="linkedin" />
                </a>
                <a href={github} class="hover-text" target="_blank" rel="noopener noreferrer" aria-label="GitHub Profile">
                    <span class="tooltip-text">GitHub</span>
                    <Icon name="github" />
                </a>
            </div>
        </div>
        <div class="image">
            <img
                src={profileImage}
                alt="Profile photo of Ioannis E. Kosmadakis"
                width="1122"
                height="1122"
                decoding="async"
                fetchpriority="high"
            />
        </div>
    </div>
</div>
