---
import Icon from './Icon.astro';

const { projects } = Astro.props;

import '../styles/projects.css';
---

<div class="container">
    <div class="projects-container">
        <div class="projects-header">
            <h1>Self-Hosted Projects</h1>
            <p>Here are open-source projects I'm running on my own infrastructure. These tools were created by talented developers in the community and I've deployed them for personal use and experimentation. Check out the original repositories to explore their features!</p>
        </div>

        <div class="projects-grid">
            {projects.map(project => (
                <div class="project-card">
                    <h2>{project.title}</h2>
                    <p>{project.description}</p>
                    <div class="project-links">
                        <a href={project.url} class="project-link" target="_blank" rel="noopener noreferrer" aria-label={`View ${project.title} live demo`}>
                            <Icon name="globe" />
                            View Project
                        </a>
                        {project.github ? (
                            <a href={project.github} class="project-link" target="_blank" rel="noopener noreferrer" aria-label={`View ${project.title} source code on GitHub`}>
                                <Icon name="github" />
                                GitHub
                            </a>
                        ) : (
                            <span class="project-link disabled" aria-label="Private repository">
                                <Icon name="github" />
                                Private
                            </span>
                        )}
                    </div>
                </div>
            ))}
        </div>

        <div class="back-home">
            <a href="/projects" class="back-link">
                <Icon name="folder" />
                My Projects
            </a>
            <a href="/" class="back-link">
                <Icon name="arrow-left" />
                Back to Home
            </a>
        </div>
    </div>
</div>
