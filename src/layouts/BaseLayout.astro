---
const { 
  title = 'Personal Card',
  description = 'My professional card and portfolio',
  isPerson = false,
} = Astro.props;
import '../styles/global.css';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/images/profile.webp', Astro.site);
const ogImageAlt = 'Profile photo of Ioannis E. Kosmadakis';
---

<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <meta name="author" content="Ioannis E. Kosmadakis">
    <meta name="robots" content="index, follow">
    <meta name="theme-color" content="#024945">

    <!-- Open Graph / Social Media -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:url" content={canonicalURL}>
    <meta property="og:type" content="website">
    <meta property="og:image" content={ogImage}>
    <meta property="og:image:type" content="image/webp">
    <meta property="og:image:width" content="1122">
    <meta property="og:image:height" content="1122">
    <meta property="og:image:alt" content={ogImageAlt}>
    <meta property="og:locale" content="en_US">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={ogImage}>
    <meta name="twitter:image:alt" content={ogImageAlt}>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL}>

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;500&display=swap" rel="stylesheet">

    <title>{title}</title>
    
    <!-- Structured Data -->
    {isPerson && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Ioannis E. Kosmadakis",
        "jobTitle": "Senior ServiceNow Technical Consultant | R&D Engineer",
        "url": "https://iekosmadakis.com",
        "image": "https://iekosmadakis.com/images/profile.webp",
        "sameAs": [
          "https://www.linkedin.com/in/iekosmadakis/",
          "https://github.com/iekosmadakis/"
        ]
      })} />
    )}
  </head>
  <body>
    <main><slot /></main>
    <footer class="site-footer">
      <p>Copyright © 2026 Ioannis E. Kosmadakis</p>
    </footer>
  </body>
</html>