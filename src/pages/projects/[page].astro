---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Projects from "../../components/Projects.astro";
import projectsData from "../../data/projects.json";

const ITEMS_PER_PAGE = 4;
const allProjects = projectsData.projects;
const totalPages = Math.ceil(allProjects.length / ITEMS_PER_PAGE);

export function getStaticPaths() {
  const perPage = 4;
  const pages = Math.ceil(projectsData.projects.length / perPage);

  return Array.from({ length: pages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const { page } = Astro.params;
const currentPage = Number(page);
const start = (currentPage - 1) * ITEMS_PER_PAGE;
const pageProjects = allProjects.slice(start, start + ITEMS_PER_PAGE);
---

<BaseLayout
  title={`Projects - Page ${currentPage} | Ioannis E. Kosmadakis | Portfolio`}
  description={`Browse more projects by Ioannis E. Kosmadakis — page ${currentPage} of ${totalPages}. Discover applications spanning automation, open-source tooling, and web development.`}
>
  <Projects projects={pageProjects} currentPage={currentPage} totalPages={totalPages} />
</BaseLayout>
