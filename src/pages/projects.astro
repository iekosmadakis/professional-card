---
import BaseLayout from "../layouts/BaseLayout.astro";
import Projects from "../components/Projects.astro";
import projectsData from "../data/projects.json";

const ITEMS_PER_PAGE = 4;
const allProjects = projectsData.projects;
const totalPages = Math.ceil(allProjects.length / ITEMS_PER_PAGE);
const pageProjects = allProjects.slice(0, ITEMS_PER_PAGE);
---

<BaseLayout 
  title="Projects | Ioannis E. Kosmadakis | Portfolio" 
  description="Explore the projects and work of Ioannis E. Kosmadakis, featuring innovative applications in web development, security, and interactive technologies."
>
  <Projects projects={pageProjects} currentPage={1} totalPages={totalPages} />
</BaseLayout> 